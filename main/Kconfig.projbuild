menu "SmartHome"

menu "Interfaces"

config FEATURE_INTERFACE_CLI
    bool "Enable CLI interface"
    default n

config FEATURE_INTERFACE_MQTT
    bool "Enable MQTT interface"
    default n
    select SERVICES_WIFICLIENT

if FEATURE_INTERFACE_MQTT

menu "Mqtt Configuration"  

config FEATURE_INTERFACE_MQTT_BROKERURI
    string "MQTT Broker URI"
    default "mqtt://192.168.178.65"
    depends on FEATURE_INTERFACE_MQTT

config FEATURE_INTERFACE_MQTT_DEVICEID
    string "MQTT Device ID"
    default "esp32"
    depends on FEATURE_INTERFACE_MQTT

endmenu

endif

endmenu

menu "IO Selection"

choice FEATURE_COMPONENT_GPIO2_FUNCTION
    prompt "GPIO 2 Function"
    default FEATURE_COMPONENT_GPIO2_UNUSED

config FEATURE_COMPONENT_GPIO2_UNUSED
    bool "Unused"

config FEATURE_COMPONENT_GPIO2_OUTPUT_ANALOG
    bool "PWM Output"

config FEATURE_COMPONENT_GPIO2_OUTPUT_BINARY
    bool "Binary Output"

config FEATURE_COMPONENT_GPIO2_INPUT_BINARY
    bool "Binary Input"

config FEATURE_COMPONENT_GPIO2_INPUT_ANALOG
    bool "Analog Input"

endchoice

choice FEATURE_COMPONENT_GPIO2_INPUT_BINARY_PULL
    prompt "GPIO 2 Binary Input Pull Mode"
    default FEATURE_COMPONENT_GPIO2_INPUT_BINARY_PULLUP
    depends on FEATURE_COMPONENT_GPIO2_INPUT_BINARY

config FEATURE_COMPONENT_GPIO2_INPUT_BINARY_PULLUP
    bool "Pull-up"

config FEATURE_COMPONENT_GPIO2_INPUT_BINARY_PULLDOWN
    bool "Pull-down"

config FEATURE_COMPONENT_GPIO2_INPUT_BINARY_FLOATING
    bool "Floating / no pull"

endchoice



menu "SmartHome"

menu "Interfaces"

config FEATURE_INTERFACE_CLI
    bool "Enable CLI interface"
    default n

config FEATURE_INTERFACE_MQTT
    bool "Enable MQTT interface"
    default n
    select SERVICES_WIFICLIENT

if FEATURE_INTERFACE_MQTT

menu "Mqtt Configuration"  

config FEATURE_INTERFACE_MQTT_BROKERURI
    string "MQTT Broker URI"
    default "mqtt://192.168.178.65"
    depends on FEATURE_INTERFACE_MQTT

config FEATURE_INTERFACE_MQTT_DEVICEID
    string "MQTT Device ID"
    default "esp32"
    depends on FEATURE_INTERFACE_MQTT

endmenu

endif

endmenu

menu "Devices"

config FEATURE_DEVICE_LIGHT
    bool "Enable light device"
    default n

config FEATURE_DEVICE_LIGHT_COUNT
    int "Number of lights"
    default 1
    range 0 4
    depends on FEATURE_DEVICE_LIGHT

config FEATURE_DEVICE_LIGHT_STARTIO
    int "First light GPIO"
    default 2
    depends on FEATURE_DEVICE_LIGHT

config FEATURE_DEVICE_RELAY
    bool "Enable relay device"
    default n

config FEATURE_DEVICE_RELAY_COUNT
    int "Number of relays"
    default 1
    range 0 4
    depends on FEATURE_DEVICE_RELAY

config FEATURE_DEVICE_RELAY_STARTIO
    int "First relay GPIO"
    default 4
    depends on FEATURE_DEVICE_RELAY

config FEATURE_DEVICE_SENSOR
    bool "Enable sensor device"
    default n

config FEATURE_DEVICE_SENSOR_COUNT
    int "Number of sensors"
    default 1
    range 0 4
    depends on FEATURE_DEVICE_SENSOR

config FEATURE_DEVICE_SENSOR_STARTIO
    int "First sensor GPIO"
    default 5
    depends on FEATURE_DEVICE_SENSOR

endmenu

menu "Services"

config SERVICES_WIFIAP
    bool "Enable WiFi Access Point"
    default n

config SERVICES_WIFICLIENT
    bool "Enable WiFi client"
    default n

if SERVICES_WIFICLIENT

menu "WiFi Configuration"

config SERVICES_WIFICLIENT_SSID
    string "WiFi SSID"
    default "Ovolus"

config SERVICES_WIFICLIENT_PASSWORD
    string "WiFi Password"
    default "Bolzplatz.2025"

config SERVICES_WIFICLIENT_DNSSERVER
    string "DNS Server"
    default "192.168.178.65"

endmenu

endif

config SERVICES_SYSTIME
    bool "Enable system time service"
    default n

endmenu

endmenu
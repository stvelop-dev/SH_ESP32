menu "Services"

config SERVICES_WIFIAP
    bool "Enable WiFi Access Point"
    default n

config SERVICES_WIFICLIENT
    bool "Enable WiFi client"
    default n

if SERVICES_WIFICLIENT

menu "WiFi Configuration"

config SERVICES_WIFICLIENT_SSID
    string "WiFi SSID"
    default "Ovolus"

config SERVICES_WIFICLIENT_PASSWORD
    string "WiFi Password"
    default "Bolzplatz.2025"

config SERVICES_WIFICLIENT_DNSSERVER
    string "DNS Server"
    default "192.168.178.65"

endmenu

endif

config SERVICES_SYSTIME
    bool "Enable system time service"
    default n

endmenu

endmenu